# Personal Data Bank (PDB) — Environment Variables (template)
# Copy to .env and fill real values. NEVER commit .env to git.

# OpenRouter — for LLM calls (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Stripe Payment (v5.9.2)
# Use TEST keys for dev (pk_test_..., sk_test_...) and LIVE keys for production (pk_live_..., sk_live_...)
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook signing secret — get from Stripe webhook endpoint settings
# REQUIRED in production (do NOT leave empty — disables signature verification)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price ID for Starter subscription product
STRIPE_STARTER_PRICE_ID=price_your_starter_price_id

# Base URL for redirects (Stripe success/cancel pages)
APP_BASE_URL=http://localhost:8000

# Optional — admin password for MCP tool gating (default "1234" — CHANGE in production)
# ADMIN_PASSWORD=change_me

# Optional — JWT signing secret (auto-generated to .jwt_secret if unset)
# JWT_SECRET_KEY=

# Google Drive BYOS (v7.0.0) — Bring Your Own Storage
# ─────────────────────────────────────────────────────────────────────────
# ทั้งหมด optional — ถ้าว่าง = BYOS feature จะปิดเงียบๆ (endpoint ตอบ 503)
# Managed Mode ทำงานปกติ ไม่กระทบ
#
# Setup: ดู docs/BYOS_SETUP.md สำหรับ Google Cloud Console 6-step guide
# ─────────────────────────────────────────────────────────────────────────

# OAuth 2.0 — จาก Google Cloud Console > APIs & Services > Credentials
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your_client_secret_here

# OAuth callback URL (auto-derived จาก APP_BASE_URL ถ้าไม่ set)
# ต้องตรงกับ Authorized redirect URIs ใน Google Cloud Console
# GOOGLE_OAUTH_REDIRECT_URI=https://project-key.fly.dev/api/drive/oauth/callback

# Picker SDK — สำหรับให้ user เลือกไฟล์จาก Drive อื่น (ไม่ใช่ที่ app สร้าง)
GOOGLE_PICKER_API_KEY=AIzaSy_your_api_key_here
GOOGLE_PICKER_APP_ID=your_project_number  # 12-digit number from project info

# OAuth mode: "testing" (ฟรี, max 100 test users, refresh token หมดอายุ 7 วัน)
# vs "production" (verified, ต้องส่ง Google review 2-4 weeks, ไม่จำกัด)
GOOGLE_OAUTH_MODE=testing

# Refresh token encryption key — generate ครั้งเดียวเก็บใน password manager
# Command: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ CRITICAL: ห้ามทำหาย — ถ้าหาย refresh_token ทุก user จะถอดไม่ออก = ทุกคนต้อง re-connect Drive
DRIVE_TOKEN_ENCRYPTION_KEY=your_44_char_fernet_key_here
