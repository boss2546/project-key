# ─────────────────────────────────────────────────────────────────────────────
#  Personal Data Bank — environment template
# ─────────────────────────────────────────────────────────────────────────────
#  Copy to `.env` (local dev) or set via `flyctl secrets set` (production).
#  Markers:
#    [REQUIRED]   server won't start without this
#    [STRONG]     should set, fallback exists but unsafe in production
#    [FEATURE]    setting unlocks a feature; missing = feature auto-disabled
#    [OPTIONAL]   tuning knob, sensible default
#    [AUTO]       set automatically by platform (don't touch manually)
# ─────────────────────────────────────────────────────────────────────────────


# ─── Core / Boot ─────────────────────────────────────────────────────────────

# [REQUIRED] Admin override password. Boot fails (sys.exit) if empty.
# Generate: openssl rand -base64 32
ADMIN_PASSWORD=

# [REQUIRED for admin panel] Comma-separated emails granted admin plan.
# All limits become 999999 for these accounts.
ADMIN_EMAILS=you@example.com

# [STRONG] JWT signing key. Falls back to /app/data/.jwt_secret file —
# OK for single-machine, BREAKS on multi-machine scale + volume migrate.
# Generate: openssl rand -base64 64
# WARNING: never rotate after first set (invalidates all sessions).
JWT_SECRET_KEY=

# [OPTIONAL] JWT lifetime in minutes. Default = 1440 (24h).
# JWT_EXPIRE_MINUTES=1440

# [STRONG] MCP token server-wide secret. Falls back to /app/data/.mcp_secret
# file (same caveats as JWT_SECRET_KEY).
MCP_SECRET=


# ─── Public URL / CORS ───────────────────────────────────────────────────────

# [REQUIRED in production] Public base URL of this deployment.
# Affects: Stripe success/cancel URLs, OAuth redirect URI defaults, LINE webhook.
# Local dev default = http://localhost:8000
APP_BASE_URL=https://your-domain.example.com

# [OPTIONAL] Comma-separated CORS allow-list. Default = APP_BASE_URL +
# localhost:8000. Override only if hosting frontend on a different origin.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# [OPTIONAL] Alias for APP_BASE_URL in a few places. Usually leave unset.
# BASE_URL=


# ─── Data Volume ─────────────────────────────────────────────────────────────

# [AUTO on Fly] Path to persistent volume mount. Production = /app/data.
# Local dev default = repo root. SQLite db + uploads/ + summaries/ live here.
# DATA_DIR=/app/data


# ─── LLM (OpenRouter — primary) ──────────────────────────────────────────────

# [FEATURE] Without this: chat, organize, retrieve, graph build, metadata
# enrichment all fail. Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=


# ─── LLM (Google Gemini — multimodal audio/video) ────────────────────────────

# [FEATURE] Audio/video ingest (Gemini Files API). Without: those formats
# return "unsupported" but text/image/PDF still work via OpenRouter.
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# [OPTIONAL] Override default Gemini file model. Leave unset to use code default.
# GEMINI_FILE_MODEL=gemini-2.5-flash


# ─── Google OAuth (Sign-In + Drive BYOS) ─────────────────────────────────────
#
# Single OAuth client serves BOTH Google Sign-In (login) and Drive BYOS
# (file access). Create at: https://console.cloud.google.com/apis/credentials
#
# Authorized redirect URIs must include:
#   {APP_BASE_URL}/api/auth/google/callback   ← login
#   {APP_BASE_URL}/api/drive/oauth/callback   ← BYOS
#

# [FEATURE] Without these: Google login disabled, BYOS disabled.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# [OPTIONAL] OAuth mode: "testing" = unverified app, 7-day token expiry,
# max 100 test users. "production" = verified app, persistent tokens.
GOOGLE_OAUTH_MODE=testing

# [OPTIONAL] Override redirect URIs if proxy/custom domain rewrites paths.
# Default = derived from APP_BASE_URL.
# GOOGLE_OAUTH_REDIRECT_URI=
# GOOGLE_LOGIN_REDIRECT_URI=

# [REQUIRED for BYOS] Fernet key for encrypting Drive refresh_token at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: rotating invalidates all stored Drive connections.
DRIVE_TOKEN_ENCRYPTION_KEY=

# [FEATURE] Google Picker SDK (client-side file selection in BYOS UI).
# Same Cloud project as OAuth client. App ID = Cloud project number.
GOOGLE_PICKER_API_KEY=
GOOGLE_PICKER_APP_ID=


# ─── Stripe Billing ──────────────────────────────────────────────────────────
#
# Dashboard: https://dashboard.stripe.com/apikeys
# Webhook endpoint to register: {APP_BASE_URL}/api/billing/webhook
#

# [FEATURE] Without these: billing endpoints return 503.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# [REQUIRED if billing enabled] Stripe price ID for the Starter plan.
STRIPE_STARTER_PRICE_ID=

# [OPTIONAL] Dev-only — bypass webhook signature verification. NEVER set in prod.
# STRIPE_WEBHOOK_DEV_BYPASS=1


# ─── Email (Resend) ──────────────────────────────────────────────────────────
#
# Dashboard: https://resend.com/api-keys
# Sender domain must be verified in Resend before EMAIL_FROM_ADDRESS will work.
#

# [FEATURE] Without this: password reset emails fail silently.
RESEND_API_KEY=

# [OPTIONAL] Sender identity. Default = noreply@personaldatabank.fly.dev (works
# only for the canonical domain). Set to a verified sender on your domain.
EMAIL_FROM_ADDRESS=noreply@your-domain.example.com
EMAIL_FROM_NAME=Personal Data Bank


# ─── LINE Bot (Messaging API + LINE Login) ───────────────────────────────────
#
# Console: https://developers.line.biz/console
# Need TWO channels in the same Provider:
#   1. Messaging API channel  → CHANNEL_SECRET + CHANNEL_ACCESS_TOKEN
#   2. LINE Login channel     → LOGIN_CHANNEL_ID + LOGIN_CHANNEL_SECRET
# Webhook URL to set: {APP_BASE_URL}/webhook/line
#

# [FEATURE] Messaging API. Without: LINE webhook returns 503.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# [FEATURE] LINE Login (account linking inside LINE bot). Without: bot can send
# notifications but users can't link their LINE → PDB account.
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# [OPTIONAL] LINE bot basic ID for friend-add deep links. Format: @PDBBot.
LINE_BOT_BASIC_ID=

# [OPTIONAL] Override webhook base URL if different from APP_BASE_URL.
# LINE_BOT_BASE_URL=


# ─── Upload Worker Tuning (v9.4.x) ───────────────────────────────────────────

# [OPTIONAL] Disable the background extraction loop entirely (dev only).
# UPLOAD_WORKER_DISABLED=1

# [OPTIONAL] Poll interval in seconds. Default = 2.
# UPLOAD_WORKER_POLL_SEC=2

# [OPTIONAL] Stale "extracting" reset threshold in seconds. Default = 1800 (30 min).
# UPLOAD_STALE_TIMEOUT_SEC=1800

# [OPTIONAL] Max retries per file. Default = 3.
# UPLOAD_MAX_RETRY=3

# [OPTIONAL] Heartbeat file path. Default = $DATA_DIR/worker_heartbeat.txt.
# UPLOAD_HEARTBEAT_FILE=


# ─── Fly.io Platform Vars (auto-set, do NOT copy these) ──────────────────────
# FLY_APP_NAME, FLY_REGION, FLY_MACHINE_ID, FLY_ALLOC_ID, FLY_PRIVATE_IP,
# FLY_PUBLIC_IP, FLY_IMAGE_REF, FLY_VM_MEMORY_MB, PORT, PRIMARY_REGION
# These are populated by Fly's runtime — never set them yourself.
